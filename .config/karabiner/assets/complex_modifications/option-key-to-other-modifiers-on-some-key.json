{
    "title": "Change option to shift+option+(command or control) when a-z key is pressed",
    "description": "Change option to shift+option+(command or control) when a-z key is pressed",
    "rules": [
        {
            "description": "Change left-option to shift+option+command when a-z key is pressed",
            "manipulators": [
                {
                    "from": {
                        "key_code": "left_option"
                    },
                    "to": [
                        {
                            "key_code": "left_option"
                        }
                    ],
                    "to_if_other_key_pressed": [
                        {
                            "other_keys": [
                                { "key_code": "a", "modifiers": {"optional": ["option"]} },
                                { "key_code": "b", "modifiers": {"optional": ["option"]} },
                                { "key_code": "c", "modifiers": {"optional": ["option"]} },
                                { "key_code": "d", "modifiers": {"optional": ["option"]} },
                                { "key_code": "e", "modifiers": {"optional": ["option"]} },
                                { "key_code": "f", "modifiers": {"optional": ["option"]} },
                                { "key_code": "g", "modifiers": {"optional": ["option"]} },
                                { "key_code": "h", "modifiers": {"optional": ["option"]} },
                                { "key_code": "i", "modifiers": {"optional": ["option"]} },
                                { "key_code": "j", "modifiers": {"optional": ["option"]} },
                                { "key_code": "k", "modifiers": {"optional": ["option"]} },
                                { "key_code": "l", "modifiers": {"optional": ["option"]} },
                                { "key_code": "m", "modifiers": {"optional": ["option"]} },
                                { "key_code": "n", "modifiers": {"optional": ["option"]} },
                                { "key_code": "o", "modifiers": {"optional": ["option"]} },
                                { "key_code": "p", "modifiers": {"optional": ["option"]} },
                                { "key_code": "q", "modifiers": {"optional": ["option"]} },
                                { "key_code": "r", "modifiers": {"optional": ["option"]} },
                                { "key_code": "s", "modifiers": {"optional": ["option"]} },
                                { "key_code": "t", "modifiers": {"optional": ["option"]} },
                                { "key_code": "u", "modifiers": {"optional": ["option"]} },
                                { "key_code": "v", "modifiers": {"optional": ["option"]} },
                                { "key_code": "w", "modifiers": {"optional": ["option"]} },
                                { "key_code": "x", "modifiers": {"optional": ["option"]} },
                                { "key_code": "y", "modifiers": {"optional": ["option"]} },
                                { "key_code": "z", "modifiers": {"optional": ["option"]} }
                            ],
                            "to": [
                                {
                                    "key_code": "left_option",
                                    "modifiers": ["shift", "command"]
                                }
                            ]
                        }
                    ],
                    "type": "basic"
                }
            ]
        },
        {
            "description": "Change right-option to shift+option+control when a-z key is pressed (to be different with left-option)",
            "manipulators": [
                {
                    "from": {
                        "key_code": "right_option"
                    },
                    "to": [
                        {
                            "key_code": "right_option"
                        }
                    ],
                    "to_if_other_key_pressed": [
                        {
                            "other_keys": [
                                { "key_code": "a", "modifiers": {"optional": ["option"]} },
                                { "key_code": "b", "modifiers": {"optional": ["option"]} },
                                { "key_code": "c", "modifiers": {"optional": ["option"]} },
                                { "key_code": "d", "modifiers": {"optional": ["option"]} },
                                { "key_code": "e", "modifiers": {"optional": ["option"]} },
                                { "key_code": "f", "modifiers": {"optional": ["option"]} },
                                { "key_code": "g", "modifiers": {"optional": ["option"]} },
                                { "key_code": "h", "modifiers": {"optional": ["option"]} },
                                { "key_code": "i", "modifiers": {"optional": ["option"]} },
                                { "key_code": "j", "modifiers": {"optional": ["option"]} },
                                { "key_code": "k", "modifiers": {"optional": ["option"]} },
                                { "key_code": "l", "modifiers": {"optional": ["option"]} },
                                { "key_code": "m", "modifiers": {"optional": ["option"]} },
                                { "key_code": "n", "modifiers": {"optional": ["option"]} },
                                { "key_code": "o", "modifiers": {"optional": ["option"]} },
                                { "key_code": "p", "modifiers": {"optional": ["option"]} },
                                { "key_code": "q", "modifiers": {"optional": ["option"]} },
                                { "key_code": "r", "modifiers": {"optional": ["option"]} },
                                { "key_code": "s", "modifiers": {"optional": ["option"]} },
                                { "key_code": "t", "modifiers": {"optional": ["option"]} },
                                { "key_code": "u", "modifiers": {"optional": ["option"]} },
                                { "key_code": "v", "modifiers": {"optional": ["option"]} },
                                { "key_code": "w", "modifiers": {"optional": ["option"]} },
                                { "key_code": "x", "modifiers": {"optional": ["option"]} },
                                { "key_code": "y", "modifiers": {"optional": ["option"]} },
                                { "key_code": "z", "modifiers": {"optional": ["option"]} }
                            ],
                            "to": [
                                {
                                    "key_code": "right_option",
                                    "modifiers": ["shift", "control"]
                                }
                            ]
                        }
                    ],
                    "type": "basic"
                }
            ]
        }
    ]
}
